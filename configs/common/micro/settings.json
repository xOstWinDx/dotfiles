{
    "clipboard": "terminal",
    "colorscheme": "simple",
    "glob:*.bash": {
        "filetype": "shell",
        "tabsize": 4,
        "tabstospaces": true
    },
    "glob:*.conf": {
        "tabsize": 4,
        "tabstospaces": true
    },
    "glob:*.env": {
        "filetype": "ini",
        "rmtrailingws": false,
        "tabsize": 2,
        "tabstospaces": true
    },
    "glob:*.json": {
        "filetype": "json",
        "tabsize": 2,
        "tabstospaces": true
    },
    "glob:*.nginx": {
        "filetype": "nginx",
        "tabsize": 4,
        "tabstospaces": true
    },
    "glob:*.py": {
        "colorcolumn": 88,
        "filetype": "python",
        "tabsize": 4,
        "tabstospaces": true
    },
    "glob:*.sh": {
        "filetype": "shell",
        "tabsize": 4,
        "tabstospaces": true
    },
    "glob:*.yaml": {
        "filetype": "yaml",
        "tabsize": 2,
        "tabstospaces": true
    },
    "glob:*.yml": {
        "filetype": "yaml",
        "tabsize": 2,
        "tabstospaces": true
    },
    "glob:.bashrc": {
        "filetype": "shell"
    },
    "glob:.env": {
        "filetype": "ini",
        "rmtrailingws": false,
        "tabsize": 2,
        "tabstospaces": true
    },
    "glob:.env.*": {
        "filetype": "ini",
        "rmtrailingws": false,
        "tabsize": 2,
        "tabstospaces": true
    },
    "glob:Dockerfile": {
        "filetype": "dockerfile",
        "tabsize": 4,
        "tabstospaces": true
    },
    "glob:docker-compose*.yml": {
        "filetype": "yaml",
        "tabsize": 2,
        "tabstospaces": true
    },
    "glob:nginx.conf": {
        "filetype": "nginx",
        "tabsize": 4,
        "tabstospaces": true
    },
    "hlsearch": true,
    "hltaberrors": true,
    "hltrailingws": true,
    "matchbraceleft": true,
    "matchbracestyle": "highlight",
    "mkparents": true,
    "parsecursor": true,
    "rmtrailingws": true,
    "savecursor": true,
    "saveundo": true,
    "scrollbar": true,
    "scrollmargin": 5,
    "status": true,
    "statusformatl": "$(filename) $(modified) $(line):$(col) | $(opt:filetype) | $(opt:fileformat) | $(opt:encoding)",
    "statusformatr": "$(bind:ToggleHelp): help | $(bind:ToggleKeyMenu): keys",
    "tabstospaces": true,
    "truecolor": "on",
    "useprimary": false
}
